# ==================== DATABASE ====================
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/labtestbooking?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change_me

# ==================== JWT ====================
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ==================== PAYMENT ====================
APP_PAYMENT_WEBHOOK_SECRET=change_me
APP_PAYMENT_MOCK_BASE_URL=http://localhost:3000/payment/mock

# ==================== EMAIL ====================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
APP_EMAIL_ENABLED=false
APP_EMAIL_MOCK=true

# ==================== AI ====================
APP_AI_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ==================== SECURITY ====================
APP_ADMIN_IP_WHITELIST_ENABLED=false
APP_ADMIN_IP_WHITELIST_IPS=127.0.0.1,::1

# ==================== FEATURE FLAGS ====================
APP_FEATURE_API_V1_ENABLED=true
APP_FEATURE_MOCK_PAYMENTS_ONLY=true
APP_FEATURE_PUBLISH_DOMAIN_EVENTS=true
APP_FEATURE_CIRCUIT_BREAKER_ENABLED=true
APP_FEATURE_REQUEST_CORRELATION_ENABLED=true

