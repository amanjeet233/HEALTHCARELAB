    {
      "name": "Create Booking",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const token = pm.environment.get(\"patient_token\");",
              "if (!token) {",
              "    console.error(\"❌ No patient token found! Please run Login Patient first.\");",
              "    postman.setNextRequest(\"Login Patient\");",
              "    if (pm.execution && pm.execution.skipRequest) { pm.execution.skipRequest(); }",
              "}",
              "",
              "// Get valid test ID (use 1 as default, or fetch from /api/tests endpoint)",
              "const testId = 1;",
              "",
              "// Get tomorrow's date",
              "const today = new Date();",
              "const tomorrow = new Date(today);",
              "tomorrow.setDate(tomorrow.getDate() + 1);",
              "",
              "const year = tomorrow.getFullYear();",
              "const month = String(tomorrow.getMonth() + 1).padStart(2, '0');",
              "const day = String(tomorrow.getDate()).padStart(2, '0');",
              "",
              "pm.variables.set(\"booking_date\", `${year}-${month}-${day}`);",
              "pm.variables.set(\"lab_test_id\", testId);",
              "",
              "// Log for debugging",
              "console.log(\"Booking date:\", pm.variables.get(\"booking_date\"));",
              "console.log(\"Lab Test ID:\", testId);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 Created\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "if (jsonData.success && jsonData.data.id) {",
              "    pm.environment.set(\"created_booking_id\", jsonData.data.id);",
              "    pm.environment.set(\"created_booking_ref\", jsonData.data.bookingReference);",
              "    console.log(\"✅ Booking created with ID:\", jsonData.data.id);",
              "    console.log(\"✅ Booking Reference:\", jsonData.data.bookingReference);",
              "}",
              "",
              "pm.test(\"Response has booking data\", function () {",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.data).to.have.property('bookingReference');",
              "    pm.expect(jsonData.data).to.have.property('patientId');",
              "    pm.expect(jsonData.data).to.have.property('labTestId');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{patient_token}}",
            "type": "text"
          }
