{
	"info": {
		"name": "🏥 Healthcare Lab - Enterprise API Suite",
		"description": "Premium REST API collection for the Healthcare Lab Test Booking System. \n\n**Maintained by:** AMANJEET KUMAR (@amanjeet233)\n**Version:** 1.2.0\n**Target Environment:** Localhost / Production",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "🔐 Auth & Identity",
			"item": [
				{
					"name": "User Registration",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"{{user_name}}\",\n  \"email\": \"{{patient_email}}\",\n  \"password\": \"{{patient_password}}\",\n  \"phone\": \"{{user_phone}}\",\n  \"gender\": \"MALE\",\n  \"age\": 25,\n  \"address\": \"New Delhi, India\",\n  \"dateOfBirth\": \"1999-01-01\",\n  \"role\": \"PATIENT\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"register"
							]
						}
					}
				},
				{
					"name": "Patient Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data.accessToken) {",
									"    pm.environment.set(\"patient_token\", jsonData.data.accessToken);",
									"    pm.environment.set(\"patient_id\", jsonData.data.userId);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{patient_email}}\",\n  \"password\": \"{{patient_password}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						}
					}
				},
				{
					"name": "Get Profile Info",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{patient_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/users/profile",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"users",
								"profile"
							]
						}
					}
				}
			]
		},
		{
			"name": "🧪 Catalog & Search",
			"item": [
				{
					"name": "Get Popular Tests",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/api/lab-tests/popular",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"lab-tests",
								"popular"
							]
						}
					}
				},
				{
					"name": "Advanced Filter & Search",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/api/lab-tests/advanced?search=Blood&category=Blood Studies&min_price=100&max_price=5000",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"lab-tests",
								"advanced"
							],
							"query": [
								{ "key": "search", "value": "Blood" },
								{ "key": "category", "value": "Blood Studies" },
								{ "key": "min_price", "value": "100" },
								{ "key": "max_price", "value": "5000" }
							]
						}
					}
				},
				{
					"name": "Get Test by Slug (Test Code)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/api/lab-tests/slug/complete-blood-count-1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"lab-tests",
								"slug",
								"complete-blood-count-1"
							]
						}
					}
				}
			]
		},
		{
			"name": "📅 Appointments & Bookings",
			"item": [
				{
					"name": "Create Appointment",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.success) {",
									"    pm.environment.set(\"created_booking_id\", jsonData.data.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{patient_token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"labTestId\": 1,\n  \"bookingDate\": \"2026-05-01\",\n  \"timeSlot\": \"10:00 AM\",\n  \"collectionType\": \"HOME\",\n  \"discount\": 0\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/bookings",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"bookings"
							]
						}
					}
				},
				{
					"name": "Get My Bookings",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{patient_token}}" }
						],
						"url": {
							"raw": "{{base_url}}/api/user-bookings",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"user-bookings"
							]
						}
					}
				}
			]
		},
		{
			"name": "📋 Diagnostic Reports",
			"item": [
				{
					"name": "Submit Test Results",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{technician_token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"bookingId\": {{created_booking_id}},\n  \"results\": [\n    {\n      \"parameterId\": 1,\n      \"resultValue\": \"14.5\",\n      \"status\": \"NORMAL\"\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/reports/results",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"reports",
								"results"
							]
						}
					}
				},
				{
					"name": "Get Final Report",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{patient_token}}" }
						],
						"url": {
							"raw": "{{base_url}}/api/reports/booking/{{created_booking_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"reports",
								"booking",
								"{{created_booking_id}}"
							]
						}
					}
				}
			]
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"console.log(\"Executing Request: \" + pm.info.requestName);"
				]
			}
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		}
	]
}
