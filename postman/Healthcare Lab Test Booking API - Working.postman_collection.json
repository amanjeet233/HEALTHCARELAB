    {
      "name": "Login Patient",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Auto-register patient if not already registered (409 = already exists, OK).",
              "const baseUrl = pm.environment.get('base_url') || 'http://localhost:8080';",
              "const registerPayload = JSON.stringify({",
              "    name: 'Patient User',",
              "    email: 'patient@test.com',",
              "    password: 'password123',",
              "    phone: '9876543210',",
              "    gender: 'MALE',",
              "    age: 28,",
              "    address: 'Delhi',",
              "    dateOfBirth: '1997-01-01',",
              "    bloodGroup: 'O+',",
              "    role: 'PATIENT'",
              "});",
              "",
              "pm.sendRequest({",
              "    url: baseUrl + '/api/auth/register',",
              "    method: 'POST',",
              "    header: { 'Content-Type': 'application/json' },",
              "    body: { mode: 'raw', raw: registerPayload }",
              "}, function (err, res) {",
              "    if (err) { console.log('Pre-register request error:', err); }",
              "    else { console.log('Pre-register patient status:', res.code); }",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();",
              "if (jsonData.success && jsonData.data.accessToken) {",
              "    pm.environment.set(\"patient_token\", jsonData.data.accessToken);",
              "    if (jsonData.data.userId) { pm.environment.set(\"patient_id\", jsonData.data.userId); }",
              "    console.log(\"Patient token saved: \" + jsonData.data.accessToken.substring(0, 20) + \"...\");",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"patient@test.com\",\n  \"password\": \"password123\"\n}",
          "options": {
            "raw": {
