    {
      "name": "Submit Report Results",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const token = pm.environment.get(\"technician_token\");",
              "if (!token) {",
              "    console.error(\"❌ No technician token found! Please run Login Technician first.\");",
              "    postman.setNextRequest(\"Login Technician\");",
              "    if (pm.execution && pm.execution.skipRequest) { pm.execution.skipRequest(); }",
              "} else {",
              "    console.log(\"✅ Using technician token\");",
              "}",
              "",
              "const bookingId = pm.environment.get(\"created_booking_id\");",
              "if (!bookingId) {",
              "    console.error(\"❌ No booking ID found! Please create a booking first.\");",
              "    postman.setNextRequest(\"Create Booking\");",
              "    if (pm.execution && pm.execution.skipRequest) { pm.execution.skipRequest(); }",
              "} else {",
              "    pm.variables.set(\"booking_id_for_report\", bookingId);",
              "    console.log(\"✅ Using booking ID:\", bookingId);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 Created\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response has success true\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{technician_token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bookingId\": {{booking_id_for_report}},\n  \"technicianId\": {{technician_id}},\n  \"results\": [\n    {\n      \"parameterId\": 1,\n      \"resultValue\": \"5.2\",\n      \"unit\": \"million cells/mcL\",\n      \"normalRange\": \"4.5-5.5\",\n      \"notes\": \"Normal\",\n      \"status\": \"NORMAL\"\n    },\n    {\n      \"parameterId\": 2,\n      \"resultValue\": \"13.5\",\n      \"unit\": \"g/dL\",\n      \"normalRange\": \"13.5-17.5\",\n      \"notes\": \"Normal\",\n      \"status\": \"NORMAL\"\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/reports/results",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "reports",
            "results"
          ]
        }
      }
    },
    {
      "name": "Get Report by Booking",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const bookingId = pm.environment.get(\"created_booking_id\");",
              "if (!bookingId) {",
              "    console.error(\"❌ No booking ID found! Please create a booking first.\");",
              "    postman.setNextRequest(\"Create Booking\");",
              "} else {",
              "    console.log(\"✅ Using booking ID:\", bookingId);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has report data\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "    pm.expect(jsonData.data).to.have.property('bookingId');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{patient_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/reports/booking/{{created_booking_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "reports",
            "booking",
            "{{created_booking_id}}"
          ]
        }
      }
    }
  ]
