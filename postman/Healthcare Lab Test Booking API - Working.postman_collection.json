    {
      "name": "Get Profile (Patient)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Check if token exists",
              "const token = pm.environment.get(\"patient_token\");",
              "if (!token) {",
              "    console.log(\"No token found! Please run Login Patient first.\");",
              "    postman.setNextRequest(\"Login Patient\");",
              "} else {",
              "    // Optional: Decode token to check expiry",
              "    try {",
              "        const base64Url = token.split('.')[1];",
              "        const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');",
              "        const payload = JSON.parse(atob(base64));",
              "",
              "        const expiryDate = new Date(payload.exp * 1000);",
              "        const now = new Date();",
              "",
              "        if (expiryDate < now) {",
              "            console.log(\"Token expired! Please login again.\");",
              "            pm.environment.unset(\"patient_token\");",
              "            postman.setNextRequest(\"Login Patient\");",
              "        } else {",
              "            console.log(\"Token valid until: \" + expiryDate);",
              "        }",
              "    } catch (e) {",
              "        console.log(\"Could not decode token\");",
              "    }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{patient_token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/users/profile",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "users",
            "profile"
          ]
        }
      }
    },
